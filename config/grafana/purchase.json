          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  session_id, purchase_id,\n  uid, email, username, pixel_id,\n  price_id, price, \n  product_title,\n  'UNKNOWN' AS \"first purchase\",\n  $__time(created_at)\nFROM (\n  SELECT\n    purchase.id AS purchase_id, session_id, uid,\n    product_id, price_id, price, title AS product_title\n  FROM errows.purchase\n  JOIN errows.products ON product_id = products.id\n  WHERE $__timeFilter(created_at)\n) purchase\nJOIN LATERAL (\n  SELECT \n    created_at\n  FROM\n    stripe_events\n  WHERE purchase.session_id = (event #>> '{data,object,id}')\n    AND event ->> 'type' = 'checkout.session.completed'\n) stripe_events ON TRUE\nLEFT JOIN LATERAL (\n  SELECT\n    email, name as username,\n    pixel ->> 'pixel_id' AS pixel_id\n  FROM  errows.users\n  JOIN errows.user_email ON id = uid\n  WHERE users.id = purchase.uid\n) users ON TRUE",
          "refId": "A",
