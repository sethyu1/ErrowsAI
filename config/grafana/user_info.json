          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  id,\n  name,\n  email,\n  pixel ->> 'pixel_id' as pixel,\n  sessions, images, voices,\n  plan, plan_type, plan_util,\n  last_login_ip, user_agent,\n  created_at\nFROM\n  users\nJOIN LATERAL (\n  SELECT email FROM user_email WHERE id = uid\n) email ON TRUE\nLEFT JOIN LATERAL (\n  SELECT \n    COALESCE(stats ->> 'session_messages', '0') as sessions,\n    COALESCE(stats ->> 'media_images', '0') as images,\n    COALESCE(stats ->> 'tts', '0') as voices\n  FROM (\n    SELECT JSON_OBJECT_AGG(type, count) AS stats\n    FROM members_stats stats\n    WHERE stats.uid = users.id\n  ) stats\n) stats ON TRUE\nLEFT JOIN LATERAL (\n  SELECT\n    plan, plan_type, UPPER(stv_tr) AS plan_util\n  FROM members_plan\n  WHERE members_plan.id = users.id\n    AND stv_tr @> NOW()\n) members ON TRUE\nLEFT JOIN LATERAL (\n  SELECT\n    ip_address AS last_login_ip, user_agent\n  FROM user_login_log WHERE user_id = users.id\n  ORDER BY created_at\n  LIMIT 1\n) login_logs ON TRUE\nWHERE $__timeFilter(created_at) \nORDER BY\n  created_at DESC",
          "refId": "A",
          "sql": {
